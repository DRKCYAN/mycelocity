---
import Base from '@/layouts/Base.astro';
import TopNav from '@/components/TopNav.astro';
import { render } from 'astro:content';
import { type Calculator, calculatorById } from '@/lib/calculators';
import type { Guide } from '@/lib/guides';

export interface Props {
  guide: Guide;
}
const { guide } = Astro.props;

// Render the Markdown body into a Content component (mirrors how CalculatorShell
// server-renders its intro/formula strings — guides just render from file).
const { Content } = await render(guide);

const related = guide.data.relatedCalculators
  .map((id) => calculatorById(id))
  .filter((c): c is Calculator => Boolean(c));

const path = `/guides/${guide.id}`;
const url = new URL(path, Astro.site ?? 'https://mycelocity.com').href;

// JSON-LD structured data — Article is the accurate type for a guide.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: guide.data.title,
  description: guide.data.description,
  url,
  author: { '@type': 'Organization', name: 'Mycelocity' },
  publisher: { '@type': 'Organization', name: 'Mycelocity' },
};
---

<Base title={guide.data.seoTitle} description={guide.data.description} jsonLd={jsonLd} path={path}>
  <TopNav />

  <main>
    <div class="mx-auto max-w-4xl px-4 py-8 sm:px-6 lg:px-10 lg:py-12">
      <!-- Breadcrumb -->
      <nav class="mb-4 text-sm text-stone-500 dark:text-stone-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-accent-600 dark:hover:text-accent-400">Home</a>
        <span class="mx-1.5">/</span>
        <a href="/guides" class="hover:text-accent-600 dark:hover:text-accent-400">Guides</a>
        <span class="mx-1.5">/</span>
        <span class="text-stone-700 dark:text-stone-300">{guide.data.title}</span>
      </nav>

      <header class="mb-6">
        {
          guide.data.category && (
            <span class="inline-flex items-center rounded-sm border border-accent-200 bg-accent-50 px-2.5 py-0.5 text-xs font-semibold uppercase tracking-wider text-accent-700 dark:border-accent-800 dark:bg-accent-900/30 dark:text-accent-300">
              {guide.data.category}
            </span>
          )
        }
        <h1
          class="mt-3 text-3xl font-bold tracking-tight text-stone-900 sm:text-4xl dark:text-stone-50"
        >
          {guide.data.title}
        </h1>
        <p class="mt-3 max-w-2xl text-base leading-relaxed text-stone-600 dark:text-stone-300">
          {guide.data.description}
        </p>
      </header>

      <!-- Rendered Markdown body -->
      <article class="prose-guide">
        <Content />
      </article>

      <!-- Related calculators — same chrome as the calculator "Connected to" aside -->
      {
        related.length > 0 && (
          <aside class="mt-10 rounded-xl border border-stone-200 bg-paper p-5 dark:border-stone-800 dark:bg-stone-900">
            <h2 class="text-sm font-semibold text-stone-700 dark:text-stone-200">
              Related calculators
            </h2>
            <p class="mt-1 text-sm text-stone-500 dark:text-stone-400">
              Put this guide to work — these calculators use the numbers it covers.
            </p>
            <ul class="mt-3 flex flex-wrap gap-2">
              {related.map((c) => (
                <li>
                  <a
                    href={`/calculators#${c.slug}`}
                    class="inline-flex items-center rounded-sm border border-accent-200 bg-accent-50 px-3 py-1 text-sm font-medium text-accent-700 hover:bg-accent-100 dark:border-accent-800 dark:bg-accent-900/30 dark:text-accent-300 dark:hover:bg-accent-900/50"
                  >
                    {c.title}
                  </a>
                </li>
              ))}
            </ul>
          </aside>
        )
      }
    </div>
  </main>
</Base>
