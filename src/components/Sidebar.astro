---
import { CATEGORIES, calculatorsByCategory } from '@/lib/calculators';

export interface Props {
  activeSlug?: string;
}
const { activeSlug } = Astro.props;
---

<!-- Mobile top bar -->
<header
  class="sticky top-0 z-30 flex items-center justify-between border-b border-stone-200 bg-paper/90 px-4 py-3 backdrop-blur lg:hidden dark:border-stone-800 dark:bg-stone-950/90"
>
  <a href="/" class="flex items-center gap-2 font-bold text-stone-900 dark:text-stone-100">
    <img src="/favicon.svg" alt="" width="24" height="24" />
    Mycelocity
  </a>
  <div class="flex items-center gap-1">
    <button
      type="button"
      data-theme-toggle
      aria-label="Toggle dark mode"
      class="rounded-lg p-2 text-stone-600 hover:bg-stone-100 dark:text-stone-300 dark:hover:bg-stone-800"
    >
      <span data-theme-icon></span>
    </button>
    <button
      type="button"
      data-menu-open
      aria-label="Open menu"
      class="rounded-lg p-2 text-stone-600 hover:bg-stone-100 dark:text-stone-300 dark:hover:bg-stone-800"
    >
      ☰
    </button>
  </div>
</header>

<!-- Overlay for mobile drawer -->
<div
  data-menu-overlay
  class="fixed inset-0 z-40 hidden bg-black/40 lg:hidden"
></div>

<!-- Sidebar -->
<aside
  data-sidebar
  class="fixed inset-y-0 left-0 z-50 w-72 -translate-x-full overflow-y-auto border-r border-stone-200 bg-paper px-4 py-5 transition-transform duration-200 lg:translate-x-0 dark:border-stone-800 dark:bg-stone-950"
>
  <div class="mb-6 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 text-lg font-bold text-stone-900 dark:text-stone-100">
      <img src="/favicon.svg" alt="" width="28" height="28" />
      Mycelocity
    </a>
    <div class="flex items-center gap-1">
      <button
        type="button"
        data-theme-toggle
        aria-label="Toggle dark mode"
        class="hidden rounded-lg p-2 text-stone-600 hover:bg-stone-100 lg:block dark:text-stone-300 dark:hover:bg-stone-800"
      >
        <span data-theme-icon></span>
      </button>
      <button
        type="button"
        data-menu-close
        aria-label="Close menu"
        class="rounded-lg p-2 text-stone-600 hover:bg-stone-100 lg:hidden dark:text-stone-300 dark:hover:bg-stone-800"
      >
        ✕
      </button>
    </div>
  </div>

  <nav class="space-y-5">
    {
      CATEGORIES.map((cat) => (
        <div>
          <a
            href={`/${cat.slug}`}
            class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-stone-400 hover:text-accent-600 dark:text-stone-500 dark:hover:text-accent-400"
          >
            {cat.name}
          </a>
          <ul class="space-y-0.5">
            {calculatorsByCategory(cat.name).map((calc) => {
              const isActive = calc.slug === activeSlug;
              return (
                <li>
                  <a
                    href={`/calculators/${calc.slug}`}
                    aria-current={isActive ? 'page' : undefined}
                    class={`block border-l-2 px-3 py-2 text-sm transition-colors ${
                      isActive
                        ? 'border-chanterelle-500 bg-chanterelle-100 font-semibold text-chanterelle-800 dark:border-chanterelle-400 dark:bg-chanterelle-900/25 dark:text-chanterelle-200'
                        : 'border-transparent text-stone-600 hover:border-stone-300 hover:bg-stone-100 dark:text-stone-300 dark:hover:border-stone-700 dark:hover:bg-stone-800'
                    }`}
                  >
                    {calc.title}
                  </a>
                </li>
              );
            })}
          </ul>
        </div>
      ))
    }
  </nav>
</aside>

<script is:inline>
  (function () {
    function syncIcon() {
      const dark = document.documentElement.classList.contains('dark');
      document.querySelectorAll('[data-theme-icon]').forEach((el) => {
        el.textContent = dark ? '☀' : '🌙';
      });
    }
    function toggleTheme() {
      const root = document.documentElement;
      root.classList.toggle('dark');
      try {
        localStorage.setItem(
          'mycelocity-theme',
          root.classList.contains('dark') ? 'dark' : 'light'
        );
      } catch (e) {}
      syncIcon();
    }

    // Wire the (freshly swapped) DOM. Runs on first load and after every
    // view-transition navigation via astro:page-load.
    function setup() {
      const sidebar = document.querySelector('[data-sidebar]');
      const overlay = document.querySelector('[data-menu-overlay]');
      const open = () => {
        sidebar?.classList.remove('-translate-x-full');
        overlay?.classList.remove('hidden');
      };
      const close = () => {
        sidebar?.classList.add('-translate-x-full');
        overlay?.classList.add('hidden');
      };
      document.querySelectorAll('[data-menu-open]').forEach((b) => b.addEventListener('click', open));
      document.querySelectorAll('[data-menu-close]').forEach((b) => b.addEventListener('click', close));
      overlay?.addEventListener('click', close);
      document.querySelectorAll('[data-theme-toggle]').forEach((b) => b.addEventListener('click', toggleTheme));
      syncIcon();
    }

    // Register the navigation hook exactly once, even if this inline script
    // re-executes on subsequent navigations.
    if (!window.__myceloNavBound) {
      window.__myceloNavBound = true;
      document.addEventListener('astro:page-load', setup);
    }
  })();
</script>
