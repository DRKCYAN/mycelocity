---
// Sticky top navigation — replaces the old left sidebar. Active-state
// highlighting is computed from Astro.url.pathname directly, so pages render
// this with no props (unlike the old Sidebar, which needed activeSlug passed in).
import { CATEGORIES, calculatorsByCategory } from '@/lib/calculators';

const path = Astro.url.pathname;
const isToolsActive = path.startsWith('/calculators') || CATEGORIES.some((c) => path === `/${c.slug}`);
const isResourcesActive = path.startsWith('/guides');
const isPricingActive = path.startsWith('/pricing');
const isAboutActive = path.startsWith('/about');

const navLinkClass = (active: boolean) =>
  `rounded-lg px-3 py-2 text-sm font-medium transition-colors ${
    active
      ? 'text-accent-700 dark:text-accent-400'
      : 'text-stone-600 hover:text-accent-700 dark:text-stone-300 dark:hover:text-accent-400'
  }`;
---

<header
  class="sticky top-0 z-30 border-b border-stone-200 bg-paper/90 backdrop-blur dark:border-stone-800 dark:bg-stone-950/90"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6 lg:px-10">
    <a href="/" class="flex items-center gap-2 text-lg font-bold text-stone-900 dark:text-stone-100">
      <img src="/favicon.svg" alt="" width="28" height="28" />
      Mycelocity
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-1 lg:flex">
      <div class="relative" data-dropdown>
        <button
          type="button"
          data-dropdown-toggle
          aria-haspopup="true"
          aria-expanded="false"
          class={`flex items-center gap-1 ${navLinkClass(isToolsActive)}`}
        >
          Tools
          <span aria-hidden="true" class="text-xs">▾</span>
        </button>
        <div
          data-dropdown-panel
          class="absolute left-0 z-40 mt-2 hidden w-[34rem] gap-4 rounded-xl border border-stone-200 bg-paper p-5 shadow-lg sm:grid sm:grid-cols-2 dark:border-stone-800 dark:bg-stone-900"
        >
          {
            CATEGORIES.map((cat) => (
              <div>
                <a
                  href={`/${cat.slug}`}
                  class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-stone-400 hover:text-accent-600 dark:text-stone-500 dark:hover:text-accent-400"
                >
                  {cat.name}
                </a>
                <ul class="space-y-0.5">
                  {calculatorsByCategory(cat.name).map((calc) => (
                    <li>
                      <a
                        href={`/calculators/${calc.slug}`}
                        class="block rounded-md px-2 py-1.5 text-sm text-stone-600 hover:bg-stone-100 hover:text-accent-700 dark:text-stone-300 dark:hover:bg-stone-800 dark:hover:text-accent-400"
                      >
                        {calc.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>

      <a href="/guides" class={navLinkClass(isResourcesActive)}>Resources</a>
      <a href="/pricing" class={navLinkClass(isPricingActive)}>Pricing</a>
      <a href="/about" class={navLinkClass(isAboutActive)}>About</a>
    </nav>

    <div class="flex items-center gap-1">
      <button
        type="button"
        data-theme-toggle
        aria-label="Toggle dark mode"
        class="rounded-lg p-2 text-stone-600 hover:bg-stone-100 dark:text-stone-300 dark:hover:bg-stone-800"
      >
        <span data-theme-icon></span>
      </button>
      <button
        type="button"
        data-menu-open
        aria-label="Open menu"
        class="rounded-lg p-2 text-stone-600 hover:bg-stone-100 lg:hidden dark:text-stone-300 dark:hover:bg-stone-800"
      >
        ☰
      </button>
    </div>
  </div>

  <!-- Mobile panel -->
  <div
    data-mobile-panel
    class="hidden max-h-[calc(100vh-3.5rem)] overflow-y-auto border-t border-stone-200 bg-paper px-4 py-4 lg:hidden dark:border-stone-800 dark:bg-stone-950"
  >
    <nav class="space-y-5">
      <div>
        <p class="mb-1.5 text-xs font-semibold uppercase tracking-wider text-stone-400 dark:text-stone-500">
          Tools
        </p>
        <div class="space-y-4">
          {
            CATEGORIES.map((cat) => (
              <div>
                <a
                  href={`/${cat.slug}`}
                  class="mb-1 block text-xs font-semibold text-stone-500 hover:text-accent-600 dark:text-stone-400 dark:hover:text-accent-400"
                  data-menu-close
                >
                  {cat.name}
                </a>
                <ul class="space-y-0.5">
                  {calculatorsByCategory(cat.name).map((calc) => (
                    <li>
                      <a
                        href={`/calculators/${calc.slug}`}
                        data-menu-close
                        class="block rounded-md px-2 py-1.5 text-sm text-stone-600 hover:bg-stone-100 dark:text-stone-300 dark:hover:bg-stone-800"
                      >
                        {calc.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>
      <div class="space-y-0.5 border-t border-stone-200 pt-4 dark:border-stone-800">
        <a
          href="/guides"
          data-menu-close
          class="block rounded-md px-2 py-2 text-sm font-medium text-stone-700 hover:bg-stone-100 dark:text-stone-200 dark:hover:bg-stone-800"
        >
          Resources
        </a>
        <a
          href="/pricing"
          data-menu-close
          class="block rounded-md px-2 py-2 text-sm font-medium text-stone-700 hover:bg-stone-100 dark:text-stone-200 dark:hover:bg-stone-800"
        >
          Pricing
        </a>
        <a
          href="/about"
          data-menu-close
          class="block rounded-md px-2 py-2 text-sm font-medium text-stone-700 hover:bg-stone-100 dark:text-stone-200 dark:hover:bg-stone-800"
        >
          About
        </a>
      </div>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    function syncIcon() {
      const dark = document.documentElement.classList.contains('dark');
      document.querySelectorAll('[data-theme-icon]').forEach((el) => {
        el.textContent = dark ? '☀' : '🌙';
      });
    }
    function toggleTheme() {
      const root = document.documentElement;
      root.classList.toggle('dark');
      try {
        localStorage.setItem(
          'mycelocity-theme',
          root.classList.contains('dark') ? 'dark' : 'light'
        );
      } catch (e) {}
      syncIcon();
    }

    // Wire the (freshly swapped) DOM. Runs on first load and after every
    // view-transition navigation via astro:page-load.
    function setup() {
      const mobilePanel = document.querySelector('[data-mobile-panel]');
      const openMobile = () => mobilePanel?.classList.remove('hidden');
      const closeMobile = () => mobilePanel?.classList.add('hidden');
      document.querySelectorAll('[data-menu-open]').forEach((b) => b.addEventListener('click', () => {
        mobilePanel?.classList.toggle('hidden');
      }));
      document.querySelectorAll('[data-menu-close]').forEach((b) => b.addEventListener('click', closeMobile));

      const dropdown = document.querySelector('[data-dropdown]');
      const toggle = dropdown?.querySelector('[data-dropdown-toggle]');
      const panel = dropdown?.querySelector('[data-dropdown-panel]');
      const closeDropdown = () => {
        panel?.classList.add('hidden');
        toggle?.setAttribute('aria-expanded', 'false');
      };
      toggle?.addEventListener('click', (e) => {
        e.stopPropagation();
        const isOpen = !panel?.classList.contains('hidden');
        if (isOpen) {
          closeDropdown();
        } else {
          panel?.classList.remove('hidden');
          toggle?.setAttribute('aria-expanded', 'true');
        }
      });
      document.addEventListener('click', (e) => {
        if (dropdown && !dropdown.contains(e.target)) closeDropdown();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          closeDropdown();
          closeMobile();
        }
      });

      document.querySelectorAll('[data-theme-toggle]').forEach((b) => b.addEventListener('click', toggleTheme));
      syncIcon();
    }

    if (!window.__myceloNavBound) {
      window.__myceloNavBound = true;
      document.addEventListener('astro:page-load', setup);
    }
  })();
</script>
