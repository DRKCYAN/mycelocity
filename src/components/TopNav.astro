---
// Sticky top navigation — replaces the old left sidebar. Active-state
// highlighting is computed from Astro.url.pathname directly, so pages render
// this with no props (unlike the old Sidebar, which needed activeSlug passed in).
import { CATEGORIES, calculatorsByCategory } from '@/lib/calculators';

const path = Astro.url.pathname;
const isToolsActive = path.startsWith('/calculators') || CATEGORIES.some((c) => path === `/${c.slug}`);
const isResourcesActive = path.startsWith('/guides');
const isPricingActive = path.startsWith('/pricing');
const isAboutActive = path.startsWith('/about');

const navLinkClass = (active: boolean) =>
  `rounded-lg px-3 py-2 text-sm font-medium transition-colors duration-150 ${
    active
      ? 'text-accent-700 dark:text-accent-400'
      : 'text-stone-600 hover:text-accent-700 dark:text-stone-300 dark:hover:text-accent-400'
  }`;
---

<header
  class="sticky top-0 z-30 border-b border-stone-200 bg-paper/90 backdrop-blur dark:border-stone-800 dark:bg-stone-950/90"
>
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3 sm:px-6 lg:px-10">
    <a href="/" class="flex items-center gap-2.5 text-lg font-bold text-stone-900 dark:text-stone-100">
      <img src="/favicon.svg" alt="" width="28" height="28" />
      Mycelocity
    </a>

    <!-- Desktop nav -->
    <nav class="hidden items-center gap-2 lg:flex">
      <div class="group relative">
        <button
          type="button"
          aria-haspopup="true"
          class={`inline-flex items-center gap-1.5 ${navLinkClass(isToolsActive)}`}
        >
          <span class="leading-none">Tools</span>
          <svg
            aria-hidden="true"
            viewBox="0 0 24 24"
            width="16"
            height="16"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="shrink-0 transition-transform duration-200 group-hover:rotate-180 group-focus-within:rotate-180"
          >
            <path d="m6 9 6 6 6-6" />
          </svg>
        </button>
        <!-- Pure CSS hover dropdown: the parent nav is already `hidden lg:flex`,
             so this only needs visibility/opacity control, not display — that
             avoids the earlier bug where a responsive display utility (sm:grid)
             unconditionally overrode `hidden` at desktop widths regardless of
             hover state. group-focus-within covers keyboard users. -->
        <div
          class="invisible absolute left-0 top-full grid w-[34rem] grid-cols-2 gap-4 rounded-xl border border-stone-200 bg-paper p-5 opacity-0 shadow-lg transition-opacity duration-150 group-hover:visible group-hover:opacity-100 group-focus-within:visible group-focus-within:opacity-100 dark:border-stone-800 dark:bg-stone-900"
        >
          {
            CATEGORIES.map((cat) => (
              <div>
                <a
                  href={`/${cat.slug}`}
                  class="mb-1.5 block text-xs font-semibold uppercase tracking-wider text-stone-400 hover:text-accent-600 dark:text-stone-500 dark:hover:text-accent-400"
                >
                  {cat.name}
                </a>
                <ul class="space-y-0.5">
                  {calculatorsByCategory(cat.name).map((calc) => (
                    <li>
                      <a
                        href={`/calculators/${calc.slug}`}
                        class="block rounded-md px-2 py-1.5 text-sm text-stone-600 hover:bg-stone-100 hover:text-accent-700 dark:text-stone-300 dark:hover:bg-stone-800 dark:hover:text-accent-400"
                      >
                        {calc.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>

      <a href="/guides" class={navLinkClass(isResourcesActive)}>Resources</a>
      <a href="/pricing" class={navLinkClass(isPricingActive)}>Pricing</a>
      <a href="/about" class={navLinkClass(isAboutActive)}>About</a>
    </nav>

    <div class="flex items-center gap-1">
      <button
        type="button"
        data-theme-toggle
        aria-label="Toggle dark mode"
        class="inline-flex h-10 w-10 items-center justify-center rounded-lg text-stone-600 transition-colors duration-150 hover:bg-stone-100 hover:text-accent-700 dark:text-stone-300 dark:hover:bg-stone-800 dark:hover:text-accent-400"
      >
        <svg
          data-icon-sun
          aria-hidden="true"
          viewBox="0 0 24 24"
          width="18"
          height="18"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="hidden"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2"></path>
          <path d="M12 20v2"></path>
          <path d="m4.93 4.93 1.41 1.41"></path>
          <path d="m17.66 17.66 1.41 1.41"></path>
          <path d="M2 12h2"></path>
          <path d="M20 12h2"></path>
          <path d="m6.34 17.66-1.41 1.41"></path>
          <path d="m19.07 4.93-1.41 1.41"></path>
        </svg>
        <svg
          data-icon-moon
          aria-hidden="true"
          viewBox="0 0 24 24"
          width="18"
          height="18"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path
            d="M20.985 12.486a9 9 0 1 1-9.473-9.472c.405-.022.617.46.402.803a6 6 0 0 0 8.268 8.268c.344-.215.825-.004.803.401Z"
          ></path>
        </svg>
      </button>
      <button
        type="button"
        data-menu-open
        aria-label="Open menu"
        class="inline-flex h-10 w-10 items-center justify-center rounded-lg text-stone-600 transition-colors duration-150 hover:bg-stone-100 hover:text-accent-700 lg:hidden dark:text-stone-300 dark:hover:bg-stone-800 dark:hover:text-accent-400"
      >
        <svg
          aria-hidden="true"
          viewBox="0 0 24 24"
          width="18"
          height="18"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M4 6h16"></path>
          <path d="M4 12h16"></path>
          <path d="M4 18h16"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile panel -->
  <div
    data-mobile-panel
    class="hidden max-h-[calc(100vh-3.5rem)] overflow-y-auto border-t border-stone-200 bg-paper px-4 py-4 lg:hidden dark:border-stone-800 dark:bg-stone-950"
  >
    <nav class="space-y-5">
      <div>
        <p class="mb-1.5 text-xs font-semibold uppercase tracking-wider text-stone-400 dark:text-stone-500">
          Tools
        </p>
        <div class="space-y-4">
          {
            CATEGORIES.map((cat) => (
              <div>
                <a
                  href={`/${cat.slug}`}
                  class="mb-1 block text-xs font-semibold text-stone-500 hover:text-accent-600 dark:text-stone-400 dark:hover:text-accent-400"
                  data-menu-close
                >
                  {cat.name}
                </a>
                <ul class="space-y-0.5">
                  {calculatorsByCategory(cat.name).map((calc) => (
                    <li>
                      <a
                        href={`/calculators/${calc.slug}`}
                        data-menu-close
                        class="block rounded-md px-2 py-1.5 text-sm text-stone-600 hover:bg-stone-100 dark:text-stone-300 dark:hover:bg-stone-800"
                      >
                        {calc.title}
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            ))
          }
        </div>
      </div>
      <div class="space-y-0.5 border-t border-stone-200 pt-4 dark:border-stone-800">
        <a
          href="/guides"
          data-menu-close
          class="block rounded-md px-2 py-2 text-sm font-medium text-stone-700 hover:bg-stone-100 dark:text-stone-200 dark:hover:bg-stone-800"
        >
          Resources
        </a>
        <a
          href="/pricing"
          data-menu-close
          class="block rounded-md px-2 py-2 text-sm font-medium text-stone-700 hover:bg-stone-100 dark:text-stone-200 dark:hover:bg-stone-800"
        >
          Pricing
        </a>
        <a
          href="/about"
          data-menu-close
          class="block rounded-md px-2 py-2 text-sm font-medium text-stone-700 hover:bg-stone-100 dark:text-stone-200 dark:hover:bg-stone-800"
        >
          About
        </a>
      </div>
    </nav>
  </div>
</header>

<script is:inline>
  (function () {
    function syncIcon() {
      const dark = document.documentElement.classList.contains('dark');
      document.querySelectorAll('[data-icon-sun]').forEach((el) => el.classList.toggle('hidden', !dark));
      document.querySelectorAll('[data-icon-moon]').forEach((el) => el.classList.toggle('hidden', dark));
    }
    function toggleTheme() {
      const root = document.documentElement;
      root.classList.toggle('dark');
      try {
        localStorage.setItem(
          'mycelocity-theme',
          root.classList.contains('dark') ? 'dark' : 'light'
        );
      } catch (e) {}
      syncIcon();
    }

    // Wire the (freshly swapped) DOM. Runs on first load and after every
    // view-transition navigation via astro:page-load.
    function setup() {
      const mobilePanel = document.querySelector('[data-mobile-panel]');
      const openMobile = () => mobilePanel?.classList.remove('hidden');
      const closeMobile = () => mobilePanel?.classList.add('hidden');
      document.querySelectorAll('[data-menu-open]').forEach((b) => b.addEventListener('click', () => {
        mobilePanel?.classList.toggle('hidden');
      }));
      document.querySelectorAll('[data-menu-close]').forEach((b) => b.addEventListener('click', closeMobile));

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          closeMobile();
        }
      });

      document.querySelectorAll('[data-theme-toggle]').forEach((b) => b.addEventListener('click', toggleTheme));
      syncIcon();
    }

    if (!window.__myceloNavBound) {
      window.__myceloNavBound = true;
      document.addEventListener('astro:page-load', setup);
    }
  })();
</script>
