---
import Base from '@/layouts/Base.astro';
import Sidebar from '@/components/Sidebar.astro';
import { type Calculator, calculatorById } from '@/lib/calculators';

export interface Props {
  calc: Calculator;
}
const { calc } = Astro.props;

const connected = calc.connectedTo
  .map((id) => calculatorById(id))
  .filter((c): c is Calculator => Boolean(c));

const path = `/calculators/${calc.slug}`;
const url = new URL(path, Astro.site ?? 'https://mycelocity.com').href;

// JSON-LD structured data for the calculator page.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: calc.title,
  description: calc.metaDescription,
  url,
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  isAccessibleForFree: true,
  publisher: { '@type': 'Organization', name: 'Mycelocity' },
};
---

<Base title={calc.seoTitle} description={calc.metaDescription} jsonLd={jsonLd} path={path}>
  <Sidebar activeSlug={calc.slug} />

  <main class="lg:ml-72">
    <div class="mx-auto max-w-4xl px-4 py-8 sm:px-6 lg:px-10 lg:py-12">
      <!-- Breadcrumb -->
      <nav class="mb-4 text-sm text-stone-500 dark:text-stone-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-accent-600 dark:hover:text-accent-400">Home</a>
        <span class="mx-1.5">/</span>
        <a
          href={`/${calc.category.toLowerCase()}`}
          class="hover:text-accent-600 dark:hover:text-accent-400">{calc.category}</a
        >
        <span class="mx-1.5">/</span>
        <span class="text-stone-700 dark:text-stone-300">{calc.title}</span>
      </nav>

      <!-- Server-rendered, crawlable above-the-fold content -->
      <header class="mb-6">
        <h1 class="text-3xl font-bold tracking-tight text-stone-900 sm:text-4xl dark:text-stone-50">
          {calc.title}
        </h1>
        <p class="mt-3 max-w-2xl text-base leading-relaxed text-stone-600 dark:text-stone-300">
          {calc.intro}
        </p>
        <div
          class="mt-4 rounded-lg border border-stone-200 bg-stone-100 px-4 py-2.5 font-mono text-xs leading-relaxed text-stone-600 dark:border-stone-700 dark:bg-stone-900 dark:text-stone-400"
        >
          <span class="font-semibold text-stone-500 dark:text-stone-500">Formula&nbsp;</span>
          {calc.formula}
        </div>
      </header>

      <!-- Interactive React island slot -->
      <section class="mt-8">
        <slot />
      </section>

      <!-- "Connected to" hint — reinforces the hub value -->
      {
        connected.length > 0 && (
          <aside class="mt-10 rounded-xl border border-stone-200 bg-paper p-5 dark:border-stone-800 dark:bg-stone-900">
            <h2 class="text-sm font-semibold text-stone-700 dark:text-stone-200">
              Connected to
            </h2>
            <p class="mt-1 text-sm text-stone-500 dark:text-stone-400">
              These calculators share inputs with this one — values you set here carry over.
            </p>
            <ul class="mt-3 flex flex-wrap gap-2">
              {connected.map((c) => (
                <li>
                  <a
                    href={`/calculators/${c.slug}`}
                    class="inline-flex items-center rounded-sm border border-accent-200 bg-accent-50 px-3 py-1 text-sm font-medium text-accent-700 hover:bg-accent-100 dark:border-accent-800 dark:bg-accent-900/30 dark:text-accent-300 dark:hover:bg-accent-900/50"
                  >
                    {c.title}
                  </a>
                </li>
              ))}
            </ul>
          </aside>
        )
      }
    </div>
  </main>
</Base>
