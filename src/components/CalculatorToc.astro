---
// Desktop-only "On this page" table of contents for the consolidated calculator
// page. Reads the registry directly (same pattern as TopNav) and mirrors the
// page's section order: Grow profile → each category → its calculators. The
// tone dots match the colored markers on the sections themselves.
import { CATEGORIES, calculatorsByCategory } from '@/lib/calculators';
import { categoryTone, toneDot } from '@/lib/tones';
---

<nav
  aria-label="On this page"
  class="lg:sticky lg:top-20 lg:max-h-[calc(100vh-6rem)] lg:overflow-y-auto"
>
  <p class="mb-3 text-xs font-semibold uppercase tracking-wider text-stone-400 dark:text-stone-500">
    On this page
  </p>
  <ul class="space-y-1 border-l border-stone-200 text-sm dark:border-stone-800">
    <li>
      <a
        href="#grow-profile"
        data-toc-link
        class="-ml-px flex items-center gap-2 border-l border-transparent py-1 pl-3 text-stone-600 transition-colors hover:text-accent-700 dark:text-stone-300 dark:hover:text-accent-400"
      >
        <span class="h-2 w-2 shrink-0 rounded-full bg-accent-500"></span>
        Grow profile
      </a>
    </li>
    {
      CATEGORIES.map((cat) => {
        const tone = categoryTone(cat.name);
        return (
          <li class="mt-3">
            <a
              href={`#${cat.slug}`}
              data-toc-link
              class="-ml-px flex items-center gap-2 border-l border-transparent py-1 pl-3 font-medium text-stone-700 transition-colors hover:text-accent-700 dark:text-stone-200 dark:hover:text-accent-400"
            >
              <span class={`h-2 w-2 shrink-0 rounded-full ${toneDot[tone]}`} />
              {cat.name}
            </a>
            <ul class="mt-0.5 space-y-0.5">
              {calculatorsByCategory(cat.name).map((calc) => (
                <li>
                  <a
                    href={`#${calc.slug}`}
                    data-toc-link
                    class="-ml-px block border-l border-transparent py-1 pl-7 text-stone-500 transition-colors hover:text-accent-700 dark:text-stone-400 dark:hover:text-accent-400"
                  >
                    {calc.title}
                  </a>
                </li>
              ))}
            </ul>
          </li>
        );
      })
    }
  </ul>
</nav>

<script is:inline>
  (function () {
    function initToc() {
      const links = Array.from(document.querySelectorAll('[data-toc-link]'));
      if (!links.length) return;

      // Tear down an observer left over from a previous (view-transition) load.
      if (window.__myceloTocObserver) {
        window.__myceloTocObserver.disconnect();
      }

      const targets = [];
      links.forEach((link) => {
        const id = (link.getAttribute('href') || '').slice(1);
        const el = id && document.getElementById(id);
        if (el) targets.push(el);
      });
      if (!targets.length) return;

      function setActive(id) {
        links.forEach((link) => {
          const on = link.getAttribute('href') === '#' + id;
          link.classList.toggle('text-accent-700', on);
          link.classList.toggle('dark:text-accent-400', on);
          link.classList.toggle('font-semibold', on);
          link.classList.toggle('border-accent-500', on);
        });
      }

      const observer = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
          if (visible[0]) setActive(visible[0].target.id);
        },
        { rootMargin: '-80px 0px -70% 0px', threshold: 0 }
      );
      targets.forEach((t) => observer.observe(t));
      window.__myceloTocObserver = observer;
    }

    if (!window.__myceloTocBound) {
      window.__myceloTocBound = true;
      document.addEventListener('astro:page-load', initToc);
    }
  })();
</script>
