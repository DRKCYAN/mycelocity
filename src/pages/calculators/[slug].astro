---
// Calculators are now consolidated onto one page (/calculators). This route
// is kept as a thin redirect shell so existing bookmarks/inbound links to
// individual calculator pages still land in the right place.
import { CALCULATORS, getCalculator } from '@/lib/calculators';

export function getStaticPaths() {
  return CALCULATORS.map((calc) => ({ params: { slug: calc.slug } }));
}

const { slug } = Astro.params;
const calc = getCalculator(slug!);
if (!calc) {
  return Astro.redirect('/404');
}
return Astro.redirect(`/calculators#${calc.slug}`, 301);
---
