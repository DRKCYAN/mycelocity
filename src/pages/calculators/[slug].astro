---
// Per-calculator standalone page. Each calculator gets its own indexable URL
// (focused <h1> + intro + the live calculator + structured data) so it can rank
// for its own long-tail term, while /calculators stays the connected hub. The
// React island is the same one the hub mounts — state is a shared nanostores
// singleton, so it works standalone with sensible defaults.
import Base from '@/layouts/Base.astro';
import TopNav from '@/components/TopNav.astro';
import CalculatorIsland from '@/components/CalculatorIsland.astro';
import {
  CALCULATORS,
  getCalculator,
  calculatorById,
  type Calculator,
} from '@/lib/calculators';
import { guidesForCalculator } from '@/lib/guides';
import { categoryTone, toneChip } from '@/lib/tones';

export function getStaticPaths() {
  return CALCULATORS.map((calc) => ({ params: { slug: calc.slug } }));
}

const { slug } = Astro.params;
const calc = getCalculator(slug!);
if (!calc) {
  return Astro.redirect('/404');
}

const path = `/calculators/${calc.slug}`;
const url = new URL(path, Astro.site ?? 'https://mycelocity.com').href;
const calcsUrl = new URL('/calculators', Astro.site ?? 'https://mycelocity.com').href;

const connected = calc.connectedTo
  .map((id) => calculatorById(id))
  .filter((c): c is Calculator => Boolean(c));

// Reverse lookup: guides that explain this calculator (authored in each guide's
// `relatedCalculators` frontmatter). Gives users the "learn the concept" path
// and adds calculator → guide internal links.
const relatedGuides = await guidesForCalculator(calc.id);

// WebApplication (the tool itself) + BreadcrumbList (Home / Calculators / this).
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebApplication',
      name: calc.title,
      description: calc.description,
      url,
      applicationCategory: 'BusinessApplication',
      operatingSystem: 'Any',
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      isAccessibleForFree: true,
    },
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: new URL('/', Astro.site ?? 'https://mycelocity.com').href },
        { '@type': 'ListItem', position: 2, name: 'Calculators', item: calcsUrl },
        { '@type': 'ListItem', position: 3, name: calc.title, item: url },
      ],
    },
  ],
};
---

<Base title={calc.seoTitle} description={calc.metaDescription} jsonLd={jsonLd} path={path}>
  <TopNav />

  <main>
    <div class="mx-auto max-w-4xl px-4 py-8 sm:px-6 lg:px-10 lg:py-12">
      <!-- Breadcrumb -->
      <nav class="mb-4 text-sm text-stone-500 dark:text-stone-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-accent-600 dark:hover:text-accent-400">Home</a>
        <span class="mx-1.5">/</span>
        <a href="/calculators" class="hover:text-accent-600 dark:hover:text-accent-400">Calculators</a>
        <span class="mx-1.5">/</span>
        <span class="text-stone-700 dark:text-stone-300">{calc.title}</span>
      </nav>

      <header class="mb-6">
        <span
          class={`inline-flex items-center rounded-sm border px-2.5 py-0.5 text-xs font-semibold uppercase tracking-wider ${toneChip[categoryTone(calc.category)]}`}
        >
          {calc.category}
        </span>
        <h1 class="mt-3 text-3xl font-bold tracking-tight text-stone-900 sm:text-4xl dark:text-stone-50">
          {calc.title} Calculator
        </h1>
        <p class="mt-3 max-w-2xl text-base leading-relaxed text-stone-600 dark:text-stone-300">
          {calc.intro}
        </p>
        <div
          class="mt-4 rounded-lg border border-stone-200 bg-stone-100 px-4 py-2.5 font-mono text-xs leading-relaxed text-stone-600 dark:border-stone-700 dark:bg-stone-900 dark:text-stone-400"
        >
          <span class="font-semibold text-stone-500 dark:text-stone-500">Formula&nbsp;</span>
          {calc.formula}
        </div>
      </header>

      <!-- The live calculator (same island the hub mounts) -->
      <div class="mt-8">
        <CalculatorIsland slug={calc.slug} />
      </div>

      <!-- Back to the connected hub -->
      <div class="mt-10">
        <a
          href={`/calculators#${calc.slug}`}
          class="inline-flex items-center gap-1.5 rounded-lg bg-chanterelle-500 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-chanterelle-600"
        >
          Explore all 10 connected calculators
          <span aria-hidden="true">→</span>
        </a>
        <p class="mt-2 text-sm text-stone-500 dark:text-stone-400">
          On the hub, every calculator shares one grow profile — change a value once and yield, cost,
          profit, break-even and ROI all recompute together.
        </p>
      </div>

      <!-- Related guides → the "learn the concept behind the numbers" path -->
      {
        relatedGuides.length > 0 && (
          <aside class="mt-8 rounded-xl border border-accent-200 bg-accent-50 p-5 dark:border-accent-800 dark:bg-accent-900/20">
            <h2 class="text-sm font-semibold text-stone-700 dark:text-stone-200">Learn the concept</h2>
            <p class="mt-1 text-sm text-stone-500 dark:text-stone-400">
              Guides that explain the numbers behind this calculator.
            </p>
            <ul class="mt-3 space-y-2">
              {relatedGuides.map((g) => (
                <li>
                  <a
                    href={`/guides/${g.id}`}
                    class="font-medium text-accent-700 hover:text-accent-800 dark:text-accent-300 dark:hover:text-accent-200"
                  >
                    {g.data.title}
                  </a>
                  <span class="block text-sm text-stone-500 dark:text-stone-400">{g.data.description}</span>
                </li>
              ))}
            </ul>
          </aside>
        )
      }

      <!-- Connected calculators → link to their own standalone pages -->
      {
        connected.length > 0 && (
          <aside class="mt-8 rounded-xl border border-stone-200 bg-paper p-5 dark:border-stone-800 dark:bg-stone-900">
            <h2 class="text-sm font-semibold text-stone-700 dark:text-stone-200">Connected calculators</h2>
            <p class="mt-1 text-sm text-stone-500 dark:text-stone-400">
              These share inputs with this one — values you set here carry over on the hub.
            </p>
            <ul class="mt-3 flex flex-wrap gap-2">
              {connected.map((c) => (
                <li>
                  <a
                    href={`/calculators/${c.slug}`}
                    class={`inline-flex items-center rounded-sm border px-3 py-1 text-sm font-medium ${toneChip[categoryTone(c.category)]}`}
                  >
                    {c.title}
                  </a>
                </li>
              ))}
            </ul>
          </aside>
        )
      }
    </div>
  </main>
</Base>
