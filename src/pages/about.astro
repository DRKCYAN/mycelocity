---
import Base from '@/layouts/Base.astro';
import TopNav from '@/components/TopNav.astro';
---

<Base title="About | Mycelocity" description="About Mycelocity — coming soon." path="/about">
  <TopNav />

  <main>
    <div class="mx-auto flex max-w-2xl flex-col items-start px-4 py-20 sm:px-6 lg:px-10">
      <h1 class="text-3xl font-bold tracking-tight text-stone-900 sm:text-4xl dark:text-stone-50">
        About
      </h1>
      <p class="mt-3 text-stone-600 dark:text-stone-300">Coming soon.</p>
      <a
        href="/"
        class="mt-6 inline-flex items-center rounded-lg border border-stone-300 bg-paper px-5 py-2.5 text-sm font-semibold text-stone-700 hover:border-accent-400 hover:text-accent-700 dark:border-stone-700 dark:bg-stone-900 dark:text-stone-200 dark:hover:border-accent-500"
      >
        ← Back home
      </a>
    </div>
  </main>
</Base>
