---
import Base from '@/layouts/Base.astro';
import TopNav from '@/components/TopNav.astro';

// Homepage body is intentionally empty — content/layout to be decided later.
// SEO metadata is kept intact so the route stays indexable in the meantime.
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Mycelocity',
  description:
    'A central hub for mushroom growing — practical guides plus a connected suite of calculators for yield, cost, profit, capacity and ROI that all share one grow profile.',
  url: 'https://mycelocity.com/',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  isAccessibleForFree: true,
};
---

<Base
  title="Mycelocity — The Hub for Growing Mushrooms as a Business"
  description="A central hub for mushroom growing: practical guides paired with a connected suite of calculators. Yield, COGS, profit per block, break-even, capacity and ROI share one grow profile — change a value once and every calculator updates."
  jsonLd={jsonLd}
  path="/"
>
  <TopNav />

  <main>
    <div class="mx-auto flex max-w-2xl flex-col items-center px-4 py-24 text-center sm:px-6 lg:px-10">
      <h1 class="text-4xl font-bold tracking-tight text-stone-900 sm:text-5xl dark:text-stone-50">
        Mycelocity
      </h1>
      <p class="mt-4 text-lg text-stone-600 dark:text-stone-300">
        The central hub for your mushroom business.
      </p>
      <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row">
        <a
          href="/calculators"
          class="inline-flex items-center rounded-lg bg-chanterelle-500 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-chanterelle-600"
        >
          Calculators
        </a>
        <a
          href="/guides"
          class="inline-flex items-center rounded-lg border border-stone-300 bg-paper px-5 py-2.5 text-sm font-semibold text-stone-700 hover:border-accent-400 hover:text-accent-700 dark:border-stone-700 dark:bg-stone-900 dark:text-stone-200 dark:hover:border-accent-500"
        >
          Guides
        </a>
      </div>
    </div>
  </main>
</Base>
