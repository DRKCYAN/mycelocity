---
import Base from '@/layouts/Base.astro';
import Sidebar from '@/components/Sidebar.astro';
import { CATEGORIES, calculatorsByCategory, type Category } from '@/lib/calculators';

export function getStaticPaths() {
  return CATEGORIES.map((cat) => ({
    params: { category: cat.slug },
    props: { cat },
  }));
}

const { cat } = Astro.props as { cat: (typeof CATEGORIES)[number] };
const calcs = calculatorsByCategory(cat.name as Category);
const path = `/${cat.slug}`;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: `${cat.name} calculators`,
  description: cat.blurb,
  url: new URL(path, Astro.site ?? 'https://mycelocity.com').href,
  hasPart: calcs.map((c) => ({
    '@type': 'WebApplication',
    name: c.title,
    url: new URL(`/calculators/${c.slug}`, Astro.site ?? 'https://mycelocity.com').href,
  })),
};
---

<Base
  title={`${cat.name} Calculators for Mushroom Farms | Mycelocity`}
  description={`${cat.blurb} ${cat.name} calculators on Mycelocity, all sharing one connected grow profile.`}
  jsonLd={jsonLd}
  path={path}
>
  <Sidebar />

  <main class="lg:ml-72">
    <div class="mx-auto max-w-4xl px-4 py-10 sm:px-6 lg:px-10 lg:py-14">
      <nav class="mb-4 text-sm text-stone-500 dark:text-stone-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-accent-600 dark:hover:text-accent-400">Home</a>
        <span class="mx-1.5">/</span>
        <span class="text-stone-700 dark:text-stone-300">{cat.name}</span>
      </nav>

      <h1 class="text-3xl font-bold tracking-tight text-stone-900 sm:text-4xl dark:text-stone-50">
        {cat.name} calculators
      </h1>
      <p class="mt-3 max-w-2xl text-base leading-relaxed text-stone-600 dark:text-stone-300">
        {cat.blurb} Every calculator here shares the same grow profile, so values flow between them and the rest of the Mycelocity hub.
      </p>

      <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2">
        {
          calcs.map((calc) => (
            <a
              href={`/calculators/${calc.slug}`}
              class="group rounded-xl border border-stone-200 bg-paper p-5 transition-colors hover:border-chanterelle-400 dark:border-stone-800 dark:bg-stone-900 dark:hover:border-chanterelle-500"
            >
              <h2 class="text-lg font-semibold text-stone-900 group-hover:text-accent-700 dark:text-stone-100 dark:group-hover:text-accent-400">
                {calc.title}
              </h2>
              <p class="mt-1 text-sm text-stone-500 dark:text-stone-400">{calc.description}</p>
            </a>
          ))
        }
      </div>

      <div class="mt-10 flex flex-wrap gap-2">
        {
          CATEGORIES.filter((c) => c.slug !== cat.slug).map((c) => (
            <a
              href={`/${c.slug}`}
              class="rounded-sm border border-stone-200 bg-paper px-4 py-1.5 text-sm font-medium text-stone-600 hover:border-chanterelle-400 hover:text-accent-700 dark:border-stone-700 dark:bg-stone-900 dark:text-stone-300 dark:hover:text-accent-400"
            >
              {c.name} →
            </a>
          ))
        }
      </div>
    </div>
  </main>
</Base>
