---
// Category pages are now sections on the combined calculators page. This
// route is kept as a thin redirect shell so existing bookmarks/inbound links
// to category pages still land in the right place.
import { CATEGORIES } from '@/lib/calculators';

export function getStaticPaths() {
  return CATEGORIES.map((cat) => ({ params: { category: cat.slug } }));
}

const { category } = Astro.params;
return Astro.redirect(`/calculators#${category}`, 301);
---
