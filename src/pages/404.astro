---
import Base from '@/layouts/Base.astro';
import Sidebar from '@/components/Sidebar.astro';
---

<Base title="Page not found | Mycelocity" description="The page you were looking for does not exist." path="/404">
  <Sidebar />
  <main class="lg:ml-72">
    <div class="mx-auto flex max-w-2xl flex-col items-start px-4 py-20 sm:px-6 lg:px-10">
      <p class="text-sm font-semibold text-accent-600 dark:text-accent-400">404</p>
      <h1 class="mt-2 text-3xl font-bold tracking-tight text-stone-900 dark:text-stone-50">
        That page didn’t fruit.
      </h1>
      <p class="mt-3 text-stone-600 dark:text-stone-300">
        The calculator you’re looking for doesn’t exist. Head back to the hub and pick one.
      </p>
      <a
        href="/"
        class="mt-6 inline-flex items-center rounded-lg bg-chanterelle-400 px-5 py-2.5 text-sm font-semibold text-stone-900 hover:bg-chanterelle-500"
      >
        ← Back to all calculators
      </a>
    </div>
  </main>
</Base>
